# ------------------------------------------------------------------
# UK Adjusted Net Income Calculator — Configuration
# Copy this file to .env and adjust values before running.
# ------------------------------------------------------------------

# PostgreSQL connection string used by the API server.
# The hostname 'db' refers to the Docker Compose service name.
DATABASE_URL=postgres://taxapp:taxapp@db:5432/taxapp?sslmode=disable

# Secret key used to encrypt session cookies.
# IMPORTANT: Change this to a long random string for any non-local deployment.
SESSION_SECRET=change-me-in-production

# bcrypt hash cost factor for password hashing (10–14 recommended).
# Higher values are more secure but slower. 12 is a reasonable default.
BCRYPT_COST=12

# Allowed CORS origin — must match the URL you access the app from.
# Change to your domain if deploying behind a reverse proxy.
CORS_ORIGIN=http://localhost

# Internal port the API server listens on (inside the Docker network).
# You should not normally need to change this.
PORT=8080

# PostgreSQL database credentials used by the db container.
# Must match the credentials in DATABASE_URL above.
POSTGRES_USER=taxapp
POSTGRES_PASSWORD=taxapp
POSTGRES_DB=taxapp
